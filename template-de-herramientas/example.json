Este archivo NO es para producción, sino para documentación interna del equipo.
Sirve como guía para saber qué poner en cada atributo, qué opciones existen y cómo funcionan.
JSON jamas acepta comentarios

{
  "name": "NombreDeLaHerramienta",          // Nombre visible en OSINT Deck
  "favicon": "https://sitio.com/icon.png",  // URL del icono (ideal 32x32 o 64x64)

  /*────────────────────────────── 1. INFORMACIÓN GENERAL ──────────────────────────────*/
  "info": {
    "tipo": "Web",                          // Opciones: Web | API | Software | CLI | Extensión | OSINT-Distro | Repositorio | Mobile | SaaS
    "licencia": "Free",                     // Opciones: Free | Freemium | Open Source | SaaS | Trial | Pago Único | Enterprise
    "acceso": "Libre",                      // Libre | Con registro | Pago | Instalación local | Demo | Mixto
    "requiere_registro": false,             // true si pide cuenta para funciones
    "offline": false,                       // true si funciona sin Internet (ej. binario)
    "idiomas": ["en","es"],                 // ISO 639-1
    "plataformas": ["Web","Windows"],       // Sistemas compatibles
    "documentacion": "https://docs.com"     // Link a guía oficial, wiki o pdf
  },

  /*────────────────────────────── 2. DATOS OPERATIVOS ──────────────────────────────*/
  "metadata": {
    "version": "v1.0",                      // Opcional. Si no existe dejar ""
    "last_update": "2025-01-20",            // Si no se sabe dejar ""
    "verified": false,                      // Se activa cuando se verifica funcionalidad
    "source": "Carga manual"                // Quién o cómo se incorporó
  },

  /*────────────────────────────── 3. ESTADO DE SERVICIO ──────────────────────────────*/
  "status": {
    "state": "up",                          // up | down | maintenance
    "http_code": 200,                       // Código obtenido en última verificación
    "last_check": "2025-01-20 12:30"        // Cron actualiza luego
  },

  /*────────────────────────────── 4. ANALÍTICAS DE USO ──────────────────────────────*/
  "stats": {
    "clicks": 0,                            // Auto-incrementable, no se modifica a mano
    "likes": 0,
    "reports": 0
  },

  /*────────────────────────────── 5. INFORMACIÓN ADMINISTRATIVA ──────────────────────*/
  "admin": {
    "created_at": "2025-01-20",             // Fecha de alta
    "updated_at": "",                       // Se actualiza en cada edición manual
    "revision": 1                           // Se incrementa en cada modificación importante
  },

  /*────────────────────────────── 6. BADGES AUTOMÁTICOS ──────────────────────────────*/
  "badges": {
    "popular": false,                       // Se activa automáticamente si clicks > X + likes > Y
    "new": false,                           // 1° mes activo
    "reported": false,                      // Si stats.reports > 0
    "recommended": false                    // Se habilita manual o rule-based
  },

  /*────────────────────────────── 7. CONTEXTO OSINT (Útil para formación / TFI) ───────*/
  "osint_context": {
    "uso_principal": "Breve descripción operativa",
    "fase_osint": [
      "Footprinting",                       // Footprinting | Discovery | Analysis | Pivoting | Reporting...
      "Discovery"
    ],
    "nivel_tecnico": "Básico"               // Básico | Intermedio | Avanzado
  },

  /*────────────────────────────── 8. CARDS (Cada función individual) ─────────────────*/
  "cards": [
    {
      "title": "Nombre visible de la card",
      "desc": "Descripción breve de para qué sirve.",
      "url": "https://herramienta.com/lookup",

      /*─────────────── CATEGORIZACIÓN ESTRUCTURAL ───────────────*/
      "category": {
        "group": "Infraestructura",         // Macro área
        "type": "DNS Lookup",               // Subcategoría
        "code": "INF_DNS"                   // Código establecido en categorias.json
      },

      /*─────────────── TAGS PARA BUSCADOR ───────────────*/
      "tags": ["dns","mx","infraestructura"], // máximo recomendado: 4-7

      /*─────────────── INPUT CONTROLADO ───────────────*/
      "input": {
        "types": ["domain","ip"],           // Valores válidos:
                                            // "domain" | "ip" | "url" | "email" | "hash" | "headers" | "none"
                                            // Si contiene `"none"` → card no depende de input
                                            
        "example": "example.com",           // ejemplo visible en UI
                                            // para ip → "8.8.8.8"
                                            // para url → "http://example.com"

        "mode": "url",                      // Tipos:
                                            // url     → insertar input en la URL de destino
                                            // manual  → usuario escribe en la herramienta
                                            // api     → la consulta se hace internamente por API
                                            // auto    → la card intenta detectar y autocompletar

        "pattern": "lookup={input}",        // Cómo insertar el input dentro de la URL
                                            // Si mode=manual puede omitirse

        "resolve_strategy": "ask"           // Para ambigüedad entre domain+ip:
                                            // ask | prefer-domain | prefer-ip | auto
      }
    }
  ]
}
