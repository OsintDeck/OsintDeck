            "reported": false, // true si existen reportes de fallos u obsolescencia (stats.reports > 0). Útil para revisar o despriorizar la herramienta.
            "recommended": false // true si es una herramienta destacada. Puede definirse manualmente o por regla (verificada, muy usada y bien valorada).
